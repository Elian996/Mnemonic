    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "dict:import": "tsx scripts/import-dictionary.ts",
    "dict:cleanup": "tsx scripts/cleanup-dictionary.ts",
    "vocab:extract": "python3 scripts/extract-vocab-pdfs.py",
    "vocab:apply": "tsx scripts/apply-vocab-tags.ts",
