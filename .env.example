DATABASE_URL="postgresql://mnemonic:mnemonic@localhost:5432/mnemonic?schema=public"
SESSION_SECRET="replace-with-a-long-random-secret"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# 如果你使用 OpenAI 官方 API，可直接填写这个变量；自动填写和图片导入都会读取它。
OPENAI_API_KEY=""

# 缺图记忆卡批量配图使用。默认读取 OPENAI_API_KEY，模型默认 gpt-image-2。
AI_IMAGE_API_KEY=""
AI_IMAGE_BASE_URL="https://api.openai.com/v1"
AI_IMAGE_MODEL="gpt-image-2"

# 可选：更权威的英英学习词典。配置后自动填写会优先使用 Merriam-Webster Learner's Dictionary。
MERRIAM_WEBSTER_LEARNERS_API_KEY=""

# 可选：官方翻译 API 兜底。词典命中时不会覆盖词典释义；只在词典/学习词典缺失时使用。
# TRANSLATION_PROVIDER 可填 baidu、youdao，或逗号分隔的优先级，例如 "baidu,youdao"。
TRANSLATION_PROVIDER="baidu,youdao"
BAIDU_TRANSLATE_APP_ID=""
BAIDU_TRANSLATE_SECRET=""
YOUDAO_APP_KEY=""
YOUDAO_APP_SECRET=""

# 自动填写单词信息使用。兼容 OpenAI API 或其他 OpenAI-compatible 服务。
AI_AUTOFILL_API_KEY=""
AI_AUTOFILL_BASE_URL="https://api.openai.com/v1"
AI_AUTOFILL_MODEL="gpt-4.1-mini"

# 外部图片识别 Agent 使用。可与自动填写共用同一个 Key。
AI_AGENT_API_KEY=""
AI_AGENT_BASE_URL="https://api.openai.com/v1"
AI_AGENT_MODEL="gpt-4.1-mini"

# 邮箱验证码。开发环境默认会 mock；生产环境请配置真实服务并保持 EMAIL_MOCK="false"。
# EMAIL_PROVIDER 可填 resend 或 tencent-ses。
EMAIL_PROVIDER="resend"
RESEND_API_KEY=""
EMAIL_FROM="Mnemonic <noreply@your-domain.com>"
EMAIL_MOCK=""
EMAIL_VERIFICATION_SECRET="replace-with-a-long-random-secret"

# 腾讯云邮件推送 SES。使用时将 EMAIL_PROVIDER 改为 tencent-ses。
TENCENTCLOUD_SECRET_ID=""
TENCENTCLOUD_SECRET_KEY=""
TENCENT_SES_REGION="ap-hongkong"
TENCENT_SES_FROM="Mnemonic <noreply@mail.mnemonic.top>"
TENCENT_SES_TEMPLATE_ID=""
TENCENT_SES_REPLY_TO=""
