generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  EDITOR
  REVIEWER
  CONTRIBUTOR
  USER
}

enum UserStatus {
  ACTIVE
  SUSPENDED
}

enum LevelTag {
  LEVEL_2
  LEVEL_3
  COMPULSORY_EDUCATION
  PRIMARY
  MIDDLE_SCHOOL
  HIGH_SCHOOL
  GAOKAO_3500
  CET4
  CET6
  POSTGRADUATE
  IELTS
  TOEFL
}

enum WordStatus {
  EMPTY
  DRAFT
  READY
  PUBLISHED
  NEEDS_REVISION
}

enum MemoryNodeType {
  WORD
  ROOT
  PREFIX
  SUFFIX
  BLOCK
  SOUND
  SCENE
  BRIDGE
  TOPIC
}

enum MnemonicSourceType {
  OFFICIAL
  USER_PRIVATE
  USER_PUBLIC
}

enum MnemonicStatus {
  PRIVATE
  DRAFT
  PENDING_REVIEW
  APPROVED
  REJECTED
  FEATURED
  ARCHIVED
}

enum RelationType {
  WIKI_LINK
  BRIDGE
  SAME_BLOCK
  SAME_ROOT
  PREFIX_LINK
  SUFFIX_LINK
  UNLOCKS
  CONFUSABLE
  SYNONYM
  ANTONYM
  EXAMPLE
  CHAIN
}

enum ChainStatus {
  DRAFT
  PUBLISHED
}

enum VoteType {
  LIKE
}

enum ReportStatus {
  OPEN
  RESOLVED
  REJECTED
}

enum ReviewCardState {
  NEW
  LEARNING
  REVIEW
  SUSPENDED
}

enum ReviewRating {
  AGAIN
  HARD
  GOOD
  EASY
}

enum WordMarkState {
  KNOWN
  FUZZY
  UNKNOWN
}

enum ImportDraftStatus {
  DRAFT
  SAVED
  DISCARDED
}

model User {
  id                String          @id @default(cuid())
  email             String          @unique
  username          String          @unique
  displayName       String
  passwordHash      String
  avatarUrl         String?
  role              UserRole        @default(USER)
  status            UserStatus      @default(ACTIVE)
  defaultPublicMnemonics Boolean    @default(false)
  contributionScore Int             @default(0)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  mnemonicEntries   MnemonicEntry[] @relation("EntryAuthor")
  reviewedEntries   MnemonicEntry[] @relation("EntryReviewer")
  linksCreated      MemoryLink[]    @relation("LinkCreator")
  chainsCreated     MemoryChain[]   @relation("ChainCreator")
  votes             Vote[]
  bookmarks         Bookmark[]
  reports           Report[]        @relation("ReportReporter")
  handledReports    Report[]        @relation("ReportHandler")
  reviewCards       ReviewCard[]
  reviewLogs        ReviewLog[]
  wordMarks         WordMark[]
  auditLogs         AuditLog[]
  notifications     Notification[]
  mnemonicCardOrders UserMnemonicCardOrder[]
}

model Word {
  id              String            @id @default(cuid())
  word            String            @unique
  slug            String            @unique
  phoneticUk      String?
  phoneticUs      String?
  audioUkUrl      String?
  audioUsUrl      String?
  partOfSpeech    String
  meaningCn       String
  meaningEn       String?
  shortMeaningCn  String
  exampleSentence String?
  exampleTranslation String?
  levelTags       LevelTag[]
  frequencyRank   Int?
  difficulty      Int               @default(3)
  status          WordStatus        @default(EMPTY)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  mnemonicEntries MnemonicEntry[]
  bookmarks       Bookmark[]
  reviewCards     ReviewCard[]
  reviewLogs      ReviewLog[]
  wordMarks       WordMark[]
  mnemonicCardOrders UserMnemonicCardOrder[]

  @@index([status])
  @@index([word])
}

model MemoryNode {
  id          String            @id @default(cuid())
  type        MemoryNodeType
  value       String
  slug        String
  displayName String
  meaningCn   String?
  description String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  outgoing    MemoryLink[]      @relation("OutgoingLinks")
  incoming    MemoryLink[]      @relation("IncomingLinks")
  chainItems  MemoryChainItem[]

  @@unique([type, slug])
  @@index([type])
  @@index([value])
}

model MnemonicEntry {
  id                    String                 @id @default(cuid())
  targetWordId          String
  authorId              String
  sourceType            MnemonicSourceType
  status                MnemonicStatus         @default(DRAFT)
  title                 String
  splitText             String?
  contentMarkdown       String
  contentHtml           String
  plainText             String
  editorNote            String?
  reviewNote            String?
  reviewerId            String?
  reviewedAt            DateTime?
  isOfficialRecommended Boolean                @default(false)
  isPublic              Boolean                @default(false)
  sortOrder             Int                    @default(0)
  editorScore           Int                    @default(0)
  likeCount             Int                    @default(0)
  bookmarkCount         Int                    @default(0)
  reportCount           Int                    @default(0)
  viewCount             Int                    @default(0)
  effectivenessScore    Float                  @default(0)
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  targetWord            Word                   @relation(fields: [targetWordId], references: [id], onDelete: Cascade)
  author                User                   @relation("EntryAuthor", fields: [authorId], references: [id])
  reviewer              User?                  @relation("EntryReviewer", fields: [reviewerId], references: [id])
  versions              MnemonicEntryVersion[]
  links                 MemoryLink[]
  votes                 Vote[]
  bookmarks             Bookmark[]
  reports               Report[]
  reviewCards           ReviewCard[]
  reviewLogs            ReviewLog[]
  userCardOrders        UserMnemonicCardOrder[]

  @@index([targetWordId, sourceType, status])
  @@index([targetWordId, sourceType, sortOrder])
  @@index([authorId])
  @@index([status])
}

model UserMnemonicCardOrder {
  id              String        @id @default(cuid())
  userId          String
  wordId          String
  mnemonicEntryId String
  sortOrder       Int           @default(0)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  word            Word          @relation(fields: [wordId], references: [id], onDelete: Cascade)
  mnemonicEntry   MnemonicEntry @relation(fields: [mnemonicEntryId], references: [id], onDelete: Cascade)

  @@unique([userId, mnemonicEntryId])
  @@index([userId, wordId, sortOrder])
}

model MnemonicEntryVersion {
  id                String        @id @default(cuid())
  mnemonicEntryId   String
  contentMarkdown   String
  splitText         String?
  title             String
  editorId          String
  createdAt         DateTime      @default(now())
  mnemonicEntry     MnemonicEntry @relation(fields: [mnemonicEntryId], references: [id], onDelete: Cascade)
}

model MemoryLink {
  id                    String        @id @default(cuid())
  sourceNodeId          String
  targetNodeId          String
  sourceMnemonicEntryId String?
  relationType          RelationType  @default(WIKI_LINK)
  anchorText            String
  description           String?
  createdById           String
  createdAt             DateTime      @default(now())
  sourceNode            MemoryNode    @relation("OutgoingLinks", fields: [sourceNodeId], references: [id], onDelete: Cascade)
  targetNode            MemoryNode    @relation("IncomingLinks", fields: [targetNodeId], references: [id], onDelete: Cascade)
  sourceMnemonicEntry   MnemonicEntry? @relation(fields: [sourceMnemonicEntryId], references: [id], onDelete: Cascade)
  createdBy             User          @relation("LinkCreator", fields: [createdById], references: [id])

  @@index([sourceNodeId])
  @@index([targetNodeId])
  @@index([sourceMnemonicEntryId])
}

model MemoryChain {
  id          String            @id @default(cuid())
  title       String
  slug        String            @unique
  description String?
  createdById String
  status      ChainStatus       @default(DRAFT)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  createdBy   User              @relation("ChainCreator", fields: [createdById], references: [id])
  items       MemoryChainItem[]
}

model MemoryChainItem {
  id         String      @id @default(cuid())
  chainId    String
  nodeId     String
  orderIndex Int
  note       String?
  chain      MemoryChain @relation(fields: [chainId], references: [id], onDelete: Cascade)
  node       MemoryNode  @relation(fields: [nodeId], references: [id], onDelete: Cascade)

  @@unique([chainId, orderIndex])
  @@index([nodeId])
}

model Vote {
  id              String        @id @default(cuid())
  userId          String
  mnemonicEntryId String
  type            VoteType      @default(LIKE)
  createdAt       DateTime      @default(now())
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  mnemonicEntry   MnemonicEntry @relation(fields: [mnemonicEntryId], references: [id], onDelete: Cascade)

  @@unique([userId, mnemonicEntryId, type])
}

model Bookmark {
  id              String         @id @default(cuid())
  userId          String
  wordId          String
  mnemonicEntryId String?
  createdAt       DateTime       @default(now())
  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  word            Word           @relation(fields: [wordId], references: [id], onDelete: Cascade)
  mnemonicEntry   MnemonicEntry? @relation(fields: [mnemonicEntryId], references: [id], onDelete: Cascade)

  @@unique([userId, wordId, mnemonicEntryId])
}

model WordMark {
  id        String        @id @default(cuid())
  userId    String
  wordId    String
  state     WordMarkState
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  word      Word          @relation(fields: [wordId], references: [id], onDelete: Cascade)

  @@unique([userId, wordId])
  @@index([userId, state])
  @@index([wordId])
}

model Report {
  id              String        @id @default(cuid())
  reporterId      String
  mnemonicEntryId String
  reason          String
  detail          String?
  status          ReportStatus  @default(OPEN)
  handledById     String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  reporter        User          @relation("ReportReporter", fields: [reporterId], references: [id])
  mnemonicEntry   MnemonicEntry @relation(fields: [mnemonicEntryId], references: [id], onDelete: Cascade)
  handledBy       User?         @relation("ReportHandler", fields: [handledById], references: [id])
}

model ReviewCard {
  id              String          @id @default(cuid())
  userId          String
  wordId          String
  mnemonicEntryId String?
  state           ReviewCardState @default(NEW)
  dueAt           DateTime        @default(now())
  intervalDays    Int             @default(0)
  easeFactor      Float           @default(2.5)
  repetitions     Int             @default(0)
  lapses          Int             @default(0)
  lastReviewedAt  DateTime?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  word            Word            @relation(fields: [wordId], references: [id], onDelete: Cascade)
  mnemonicEntry   MnemonicEntry?  @relation(fields: [mnemonicEntryId], references: [id], onDelete: SetNull)

  @@unique([userId, wordId, mnemonicEntryId])
  @@index([userId, dueAt])
}

model ReviewLog {
  id              String        @id @default(cuid())
  userId          String
  wordId          String
  mnemonicEntryId String?
  rating          ReviewRating
  remembered      Boolean
  reviewedAt      DateTime      @default(now())
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  word            Word          @relation(fields: [wordId], references: [id], onDelete: Cascade)
  mnemonicEntry   MnemonicEntry? @relation(fields: [mnemonicEntryId], references: [id], onDelete: SetNull)

  @@index([userId, reviewedAt])
  @@index([mnemonicEntryId])
}

model AuditLog {
  id           String   @id @default(cuid())
  actorId      String
  action       String
  entityType   String
  entityId     String
  metadataJson Json?
  createdAt    DateTime @default(now())
  actor        User     @relation(fields: [actorId], references: [id])

  @@index([entityType, entityId])
}

model Notification {
  id        String    @id @default(cuid())
  userId    String
  title     String
  body      String
  href      String?
  readAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt, createdAt])
  @@index([userId, createdAt])
}

model ImportDraft {
  id              String            @id @default(cuid())
  source          String            @default("external-agent")
  status          ImportDraftStatus @default(DRAFT)
  word            String
  phoneticUk      String?
  phoneticUs      String?
  partOfSpeech    String?
  meaningCn       String?
  meaningEn       String?
  shortMeaningCn  String?
  difficulty      Int               @default(3)
  splitText       String?
  title           String?
  contentMarkdown String
  rawText         String?
  originalImageUrl String?
  extractedImageUrls String[]
  agentPayload    Json
  savedWordId     String?
  savedEntryId    String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@index([status, createdAt])
  @@index([word])
}
